{
  "name": "@toony1908/stacks-passkey-react",
  "version": "0.1.0",
  "description": "Reusable React SDK for a WebAuthn passkey (PRF)-derived Stacks hot wallet: connect, send STX, sign transactions, and recover, with per-operation FaceID/fingerprint auth.",
  "type": "module",
  "license": "MIT",
  "author": "Antonio Santiago",
  "homepage": "https://github.com/tony1908/stacks-passkey-wallet#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tony1908/stacks-passkey-wallet.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/tony1908/stacks-passkey-wallet/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "stacks",
    "passkey",
    "webauthn",
    "prf",
    "wallet",
    "react",
    "sdk",
    "hot-wallet",
    "bip39"
  ],
  "dependencies": {
    "@toony1908/stacks-passkey-core": "workspace:^"
  },
  "peerDependencies": {
    "@stacks/transactions": ">=7",
    "@stacks/wallet-sdk": ">=7",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@stacks/transactions": "^7.3.1",
    "@stacks/wallet-sdk": "^7.5.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^25.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.3.0",
    "typescript": "~5.8.2",
    "vitest": "^2.1.9"
  }
}
